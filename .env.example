ANTHROPIC_API_KEY=sk-ant-...

MAX_PAGES_PER_SITE=50

CRAWL_DELAY_SECONDS=1.5

OUTPUT_DIR=./output

DATABASE_PATH=./storage/scraping.db



# Google Maps API (opcional — sem key usa scraping Playwright como fallback)

# Obter em: console.cloud.google.com → APIs → Places API

# Cota gratuita: 200 USD/mês (~6000 buscas grátis por mês)

GOOGLE_MAPS_API_KEY=



# Supabase (obrigatório para multi-usuário)

# Criar projeto gratuito em: https://supabase.com

# Settings → API → Project URL + service_role key (secret)

# Use service_role no api.py local (anon key falha com RLS ativo)

SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

SUPABASE_KEY=eyJ...service_role...



# Fallback local (usado se Supabase não configurado)

USE_LOCAL_DB=false



# Identificação do usuário (para CRM multi-usuário)

# Cada sócio define o próprio nome aqui

USUARIO=caio



# Claude Code CLI usa a mesma ANTHROPIC_API_KEY acima.

# Gerar um site completo pode consumir ~50k-150k tokens por execução.

# Instale com: npm install -g @anthropic-ai/claude-code

