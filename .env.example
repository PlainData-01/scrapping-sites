# Prospect Hub — variáveis de ambiente

ANTHROPIC_API_KEY=
GOOGLE_MAPS_API_KEY=

# Supabase (multi-usuário)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Senha do Postgres (Settings → Database) — só para scripts/migrations locais
# SUPABASE_DB_PASSWORD=
# ou connection string completa:
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

USUARIO=caio
APP_ENV=local

# Scraping / prospecção
MAX_PAGES_PER_SITE=8
MAX_CONCURRENT_SCRAPERS=3
CRAWL_DELAY_SECONDS=1.5
OUTPUT_DIR=./output
DATABASE_PATH=./storage/scraping.db
USE_LOCAL_DB=false

# Geração de protótipos: template | claude_code | prompt_only
DEFAULT_SITE_GENERATOR_MODE=template

# PageSpeed / Lighthouse (opcional)
ENABLE_LIGHTHOUSE=false
PAGESPEED_API_KEY=

# Frontend → API (para deploy futuro na Vercel)
API_BASE_URL=http://127.0.0.1:8000

# Modelo Claude para análise
CLAUDE_MODEL=claude-sonnet-4-6
